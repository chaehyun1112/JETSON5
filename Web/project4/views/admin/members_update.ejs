<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/common.css">
  <link rel="stylesheet" href="/admin/style_members_update.css" />
</head>
<body>


    <main class="admin-main">
      <header class="admin-header">
        <div>
          <h1><%= pageTitle %></h1>
          <p>관리자 권한으로 회원의 개인정보와 회원 구분을 수정합니다.</p>
        </div>



          <div class="admin-user-dropdown" id="adminUserDropdown">
            <a href="/admin/profile">개인정보 수정</a>
            <a href="/admin/members">회원정보 수정</a>
            <a href="/">로그아웃</a>
          </div>
        </div>
      </header>

      <section class="admin-panel member-edit-panel">
        <div class="panel-header">
          <h2>회원 정보 수정</h2>
        </div>

        <form action="/admin/member/edit" method="post" class="member-edit-form">
          <div class="form-row">
            <label for="memberId">아이디</label>
            <input
              type="text"
              id="memberId"
              name="memberId"
              value="<%= member.id %>"
              readonly
            />
            <span class="readonly-text">읽기전용</span>
          </div>

          <div class="form-row">
            <label for="type">회원구분</label>
            <select id="type" name="type" required>
              <option value="P" <%= member.type === "P" ? "selected" : "" %>>보호자</option>
              <option value="S" <%= member.type === "S" ? "selected" : "" %>>피보호자</option>
              <option value="A" <%= member.type === "A" ? "selected" : "" %>>관리자</option>
            </select>
          </div>

          <div class="form-row">
            <label for="name">이름</label>
            <input
              type="text"
              id="name"
              name="name"
              value="<%= member.name %>"
              required
            />
          </div>

          <div class="form-row">
            <label for="email">이메일</label>
            <input
              type="email"
              id="email"
              name="email"
              value="<%= member.email %>"
              required
            />
          </div>

          <div class="form-row">
            <label for="contact">연락처</label>
            <input
              type="text"
              id="contact"
              name="contact"
              value="<%= member.contact %>"
              required
            />
          </div>

          <div class="form-row">
            <label for="address">주소</label>
            <input
              type="text"
              id="address"
              name="address"
              value="<%= member.address %>"
            />
          </div>

          <div class="form-row">
            <label for="joinedAt">가입일</label>
            <input
              type="text"
              id="joinedAt"
              name="joinedAt"
              value="<%= member.joinedAt %>"
              readonly
            />
            <span class="readonly-text">읽기전용</span>
          </div>

          <div class="form-actions">
            <a href="/admin/admin_dashboard/admin" class="save-btn">수정완료</a>
            <a href="/admin/admin_dashboard/admin" class="cancel-btn">취소</a>
          </div>
        </form>
      </section>
    </main>
  </div>

  <script>
    const adminUserButton = document.querySelector("#adminUserButton");
    const adminUserDropdown = document.querySelector("#adminUserDropdown");

    if (adminUserButton && adminUserDropdown) {
      adminUserButton.addEventListener("click", () => {
        adminUserDropdown.classList.toggle("show");
      });

      document.addEventListener("click", (event) => {
        const isMenuClick = event.target.closest(".admin-user-menu");

        if (!isMenuClick) {
          adminUserDropdown.classList.remove("show");
        }
      });
    }
  </script>
</body>
</html>