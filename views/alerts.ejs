<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>알림 관리</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-shell">
        <%- include("partials/sidebar", { resident: data.resident, activePage: "alerts" }) %>

        <main class="dashboard alerts-page">
            <%- include("partials/topbar", {
                title: "알림 관리",
                lastUpdated: data.lastUpdated,
                avatarLabel: "김"
            }) %>

            <section class="alerts-layout" aria-label="알림 관리">
                <%- include("partials/guardian-card", { guardian: data.guardian }) %>
                <%- include("partials/alert-history-panel", { history: data.history }) %>
            </section>
        </main>
    </div>
</body>
</html>
