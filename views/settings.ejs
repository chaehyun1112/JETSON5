<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>설정</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-shell">
        <%- include("partials/sidebar", { resident: data.resident, activePage: "settings" }) %>

        <main class="dashboard settings-page">
            <%- include("partials/topbar", {
                title: "설정",
                lastUpdated: data.lastUpdated,
                avatarLabel: "김"
            }) %>

            <%- include("partials/settings-menu", { items: data.items }) %>

            <p class="settings-version">앱 버전 <%= data.version %></p>
        </main>
    </div>
</body>
</html>
