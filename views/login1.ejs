<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/style_login.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body class="login-page">

  <div class="login-wrap">
    <div class="login-card">

      <div class="login-card__logo">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="4" y="14" width="40" height="30" rx="5" fill="#2563eb" opacity="0.12"/>
          <rect x="4" y="14" width="40" height="30" rx="5" stroke="#2563eb" stroke-width="2"/>
          <path d="M17 14V11a7 7 0 0114 0v3" stroke="#2563eb" stroke-width="2" stroke-linecap="round"/>
          <path d="M24 25v6M21 28h6" stroke="#2563eb" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <p class="login-card__service">보건원</p>
      </div>

      <h1 class="login-card__title">스파트 약 보관함</h1>
      <p class="login-card__sub">시니어의 안전한 복약 관리 웹 시스템</p>

      <form action="/login" method="POST" class="login-form">
        <div class="login-form__group">
          <label for="id">아이디</label>
          <input type="text" id="id" name="id" placeholder="아이디를 입력해 주세요" required />
        </div>
        <div class="login-form__group">
          <label for="password">비밀번호</label>
          <input type="password" id="password" name="password" placeholder="비밀번호를 입력해 주세요" required />
        </div>

        <div class="login-form__options">
          <label class="checkbox-label">
            <input type="checkbox" name="remember" />
            <span>아이디 저장</span>
          </label>
          <a href="#" class="login-form__find">비밀번호 찾기</a>
        </div>

        <button type="submit" class="btn btn--primary btn--full">로그인</button>
      </form>

      <div class="login-card__footer">
        <a href="/">← 메인으로 돌아가기</a>
      </div>

    </div>
  </div>

</body>
</html>
