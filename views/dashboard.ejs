<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/style_dashboard.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body class="db-page">

<%- include('partials/nav') %>

<!-- ===== 대시보드 헤더 ===== -->
<div class="db-header">
    <div class="db-header__inner">
<div>
        <p class="db-header__greeting">안녕하세요, <strong><%= user.name %></strong> 님 👋</p>
        <h1 class="db-header__title">오늘의 복약 현황</h1>
        <p class="db-header__date">
          <%= new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' }) %>
        </p>
      </div>
      <div class="db-header__badge-wrap">
        <span class="status-badge status-badge--live">
          <span class="status-badge__dot"></span>
          실시간 모니터링 중
        </span>
      </div>
    </div>
  </div>

  <!-- ===== 본문 ===== -->
  <main class="db-main">
    <div class="db-container">

      <!-- 통계 카드 4개 -->
      <div class="db-stats">
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <p class="db-stat-card__label">총 등록 보호대상</p>
            <p class="db-stat-card__num"><%= stats.total %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <p class="db-stat-card__label">복약 완료</p>
            <p class="db-stat-card__num db-stat-card__num--green"><%= stats.completed %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <div>
            <p class="db-stat-card__label">미복약 경보</p>
            <p class="db-stat-card__num db-stat-card__num--red"><%= stats.warning %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--purple">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div>
            <p class="db-stat-card__label">오늘 복약률</p>
            <p class="db-stat-card__num db-stat-card__num--purple"><%= stats.rate %><span>%</span></p>
          </div>
        </div>
      </div>

      <!-- 복약률 프로그레스 -->
      <div class="db-card db-rate-card">
        <div class="db-card__header">
          <h2 class="db-card__title">오늘 전체 복약률</h2>
          <span class="db-rate-card__val"><%= stats.rate %>%</span>
        </div>
        <div class="db-progress">
          <div class="db-progress__fill" style="width: <%= stats.rate %>%;"></div>
        </div>
        <p class="db-rate-card__sub">전체 <%= stats.total %>명 중 <%= stats.completed %>명 복약 완료 · <%= stats.warning %>명 미복약</p>
      </div>

      <!-- 환자 목록 + 알림 -->
      <div class="db-grid-2">

        <!-- 환자 목록 -->
        <div class="db-card">
          <div class="db-card__header">
            <h2 class="db-card__title">보호자별 복약 현황</h2>
            <a href="#" class="db-card__more">전체 보기 →</a>
          </div>
          <table class="db-table">
            <thead>
              <tr>
                <th>이름</th>
                <th>나이</th>
                <th>복약 시간</th>
                <th>상태</th>
              </tr>
            </thead>
            <tbody>
              <% patients.forEach(p => { %>
              <tr>
                <td class="db-table__name">
                  <span class="db-avatar"><%= p.name.charAt(0) %></span>
                  <%= p.name %>
                </td>
                <td><%= p.age %>세</td>
                <td><%= p.time %></td>
                <td>
                  <span class="db-status db-status--<%= p.status %>">
                    <% if (p.status === 'ok') { %>완료<% } else if (p.status === 'warn') { %>지연<% } else { %>미복약<% } %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- 알림 피드 -->
        <div class="db-card">
          <div class="db-card__header">
            <h2 class="db-card__title">최근 알림</h2>
            <a href="#" class="db-card__more">알림 관리 →</a>
          </div>
          <ul class="db-alert-list">
            <% alerts.forEach(a => { %>
            <li class="db-alert db-alert--<%= a.type %>">
              <span class="db-alert__dot"></span>
              <div class="db-alert__body">
                <p class="db-alert__msg"><%= a.message %></p>
                <p class="db-alert__time"><%= a.time %></p>
              </div>
            </li>
            <% }) %>
          </ul>
        </div>

      </div>
      <!-- /db-grid-2 -->

    </div>
  </main>

  <!-- ===== 푸터 ===== -->
  <footer class="footer">
    <div class="container">
      <p>© 2025 복약안심서비스 &nbsp;|&nbsp; Team Jetson5 &nbsp;|&nbsp; 스마트 약상자 기반 복약 관리 플랫폼</p>
    </div>
  </footer>

</body>
</html>
