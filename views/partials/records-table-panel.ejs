<section class="panel records-panel" aria-label="복약 기록">
    <div class="records-panel-head">
        <h2>복약 기록</h2>
        <button type="button" class="date-range-btn">📅 <%= range %> 🗓️</button>
    </div>

    <table class="records-table">
        <thead>
            <tr>
                <th>날짜</th>
                <th>예정 시간</th>
                <th>실제 복용 시간</th>
                <th>결과</th>
                <th>약통 상태</th>
            </tr>
        </thead>
        <tbody>
            <% records.forEach((record) => { %>
                <tr>
                    <td><%= record.date %></td>
                    <td><%= record.plannedTime %></td>
                    <td><%= record.actualTime %></td>
                    <td><span class="record-result <%= record.resultTone %>"><%= record.result %></span></td>
                    <td><span class="bottle-state <%= record.bottleTone %>"><%= record.bottleState %></span></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <nav class="pagination" aria-label="복약 기록 페이지">
        <a href="#" aria-label="이전 페이지">‹</a>
        <% pagination.pages.forEach((page) => { %>
            <a class="<%= page === pagination.current ? "active" : "" %>" href="#"><%= page %></a>
        <% }) %>
        <a href="#" aria-label="다음 페이지">›</a>
    </nav>
</section>
