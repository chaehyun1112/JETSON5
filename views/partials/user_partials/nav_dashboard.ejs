<header class="nav">
  <div class="nav__inner">

    <!-- 로고 -->
    <a href="<%= user ? '/user/user_service/about' : '/login' %>" class="nav__dropdown-trigger">
      <svg class="nav__logo-icon" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="2" y="8" width="24" height="18" rx="3" fill="#2563eb" opacity="0.15"/>
        <rect x="2" y="8" width="24" height="18" rx="3" stroke="#2563eb" stroke-width="1.5"/>
        <path d="M10 8V6a4 4 0 018 0v2" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M14 14v4M12 16h4" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      복약안심서비스
    </a>
    <!-- 메뉴 링크 -->
    <nav class="nav__links" aria-label="주요 메뉴">
      <a href="/user/user_service/about">서비스 소개</a>
      <a href="/index/index_HowToUse">이용 방법</a>

      <!-- 대시보드 드롭다운 -->
      <div class="nav__dropdown">
        <a href="<%= user ? '/user/user_dashboard/main_dashboard' : '/login' %>" class="nav__dropdown-trigger">
          대시보드
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </a>
        <div class="nav__dropdown-menu">
          <div class="nav__dropdown-menu-inner">
            <a href="/user/user_dashboard/main_dashboard">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
              메인 대시보드
            </a>
            <a href="/user/user_dashboard/dashboard_record">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
              복약 기록
            </a>
            <a href="/user/user_dashboard/dashboard_stat">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
              실시간 상태
            </a>
            <a href="/user/user_dashboard/dashboard_call">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
              알림 관리
            </a>
          </div>
        </div>
      </div>

      <a href="/index/index_announce">공지사항</a>
    </nav>

    <!-- 우측: 로그인 전/후 분기 -->
<div class="nav__actions">
      <% if (user) { %>
        <!-- 로그인 후: 사용자정보 + 보호대상정보 + 아이콘 메뉴 -->
        <a href="/user/user_info/protected" class="btn btn--ghost btn--sm">보호대상 정보</a>

        <!-- 동그라미 아이콘 + 드롭다운 -->
        <div class="nav__user-menu">
          <button class="nav__user-btn" id="userMenuBtn" aria-label="계정 메뉴" aria-expanded="false">
            <span class="nav__avatar"><%= user.name.charAt(0) %></span>
          </button>
          <div class="nav__user-dropdown" id="userMenuDropdown">
            <div class="nav__user-info">
              <strong><%= user.name %></strong>
              <span><%= user.role %></span>
            </div>
            <div class="nav__user-divider"></div>
            <a href="/user/user_info/settings" class="nav__user-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              개인정보 관리
            </a>
            <div class="nav__user-divider"></div>
            <form action="/logout" method="POST" style="margin:0;">
              <button type="submit" class="nav__user-item nav__user-item--logout">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                로그아웃
              </button>
            </form>
          </div>
        </div>

      <% } else { %>
        <!-- 로그인 전 -->
        <a href="/login" class="btn btn--primary btn--sm">로그인</a>
      <% } %>
    </div>

  </div>
</header>

<script>
  // 유저 메뉴 토글
  const userMenuBtn = document.getElementById('userMenuBtn');
  const userMenuDropdown = document.getElementById('userMenuDropdown');
  if (userMenuBtn) {
    userMenuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = userMenuDropdown.classList.toggle('is-open');
      userMenuBtn.setAttribute('aria-expanded', open);
    });
    document.addEventListener('click', () => {
      userMenuDropdown.classList.remove('is-open');
      userMenuBtn.setAttribute('aria-expanded', 'false');
    });
    userMenuDropdown.addEventListener('click', (e) => e.stopPropagation());
  }
</script>
