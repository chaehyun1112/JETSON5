<div class="panel-title">
    <h2>단계별 복약량</h2>
</div>
<div class="dose-progress-list">
    <% doseAmounts.forEach((dose) => { %>
        <div class="dose-progress">
            <div>
                <span><%= dose.label %></span>
                <strong><%= dose.value %>%</strong>
                <small><%= dose.detail %></small>
            </div>
            <div class="progress-track">
                <i style="width: <%= dose.value %>%"></i>
            </div>
        </div>
    <% }) %>
</div>

<div class="panel-title compact">
    <h2>주간 평균 복약량 추이</h2>
</div>
<div id="weeklyLineChart" class="weekly-line-chart" data-chart='<%- JSON.stringify(weeklyTrend) %>'></div>
<p class="chart-caption">일별 기준 평균 사용량(단위: g)</p>
