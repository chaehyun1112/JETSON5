<article class="panel alert-history-panel">
    <div class="panel-title">
        <h2>최근 알림 내역</h2>
    </div>

    <div class="alert-history-list">
        <% history.forEach((item) => { %>
            <div class="alert-history-item">
                <time><%= item.sentAt %></time>
                <span class="alert-type <%= item.tone %>"><%= item.type %></span>
                <p><%= item.message %></p>
            </div>
        <% }) %>
    </div>

    <a class="table-link" href="#">더보기 ›</a>
</article>
