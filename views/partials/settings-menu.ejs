<section class="settings-stack" aria-label="설정 메뉴">
    <% items.forEach((item) => { %>
        <button type="button" class="settings-item <%= item.danger ? "danger" : "" %>">
            <span class="settings-icon <%= item.tone %>"><%= item.icon %></span>
            <span class="settings-copy">
                <strong><%= item.title %></strong>
                <small><%= item.description %></small>
            </span>
            <span class="settings-arrow">›</span>
        </button>
    <% }) %>
</section>
