<article class="panel status-log-panel">
    <div class="panel-title">
        <h2>복약 인지 로그</h2>
    </div>
    <table class="status-table">
        <thead>
            <tr>
                <th>날짜</th>
                <th>시간</th>
                <th>뚜껑 상태</th>
                <th>판정</th>
            </tr>
        </thead>
        <tbody>
            <% logs.forEach((log) => { %>
                <tr>
                    <td><%= log.date %></td>
                    <td><%= log.time %></td>
                    <td><span class="status-dot <%= log.tone %>"></span><%= log.state %></td>
                    <td><span class="result-pill <%= log.tone %>"><%= log.result %></span></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a class="table-link" href="#">전체 기록 보기 →</a>
</article>
