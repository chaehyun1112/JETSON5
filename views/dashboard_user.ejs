<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>스마트 약 보관함 대시보드</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-shell">
        <%- include("partials/sidebar", { resident: data.resident, activePage: "dashboard" }) %>

        <main class="dashboard">
            <header class="topbar">
                <div>
                    <h1>대시보드</h1>
                    <p><%= data.lastUpdated %></p>
                </div>
                <div class="topbar-actions">
                    <button type="button" class="ghost-btn">리포트 내보내기</button>
                    <button type="button" class="primary-btn">알림 보내기</button>
                    <span class="avatar">김</span>
                </div>
            </header>

            <section class="notice">
                <div class="notice-icon">!</div>
                <div>
                    <strong><%= data.alert.title %></strong>
                    <p><%= data.alert.message %></p>
                </div>
                <button type="button">문자 알림 발송</button>
            </section>

            <section class="metric-grid">
                <% data.metrics.forEach((metric) => { %>
                    <article class="metric-card <%= metric.tone %>">
                        <div class="metric-head">
                            <span><%= metric.label %></span>
                            <span class="metric-icon <%= metric.tone %>"><%= metric.icon === "check" ? "✓" : metric.icon === "calendar" ? "17" : metric.icon === "flame" ? "🔥" : "!" %></span>
                        </div>
                        <div class="metric-value"><%= metric.value %><small><%= metric.suffix %></small></div>
                        <p><%= metric.note %></p>
                    </article>
                <% }) %>
            </section>

            <section class="dashboard-grid">
                <article class="panel schedule-panel">
                    <div class="panel-title">
                        <h2>오늘 복약 일정</h2>
                        <span class="pill success">2/3 완료</span>
                    </div>
                    <div class="schedule-list">
                        <% data.todaySchedule.forEach((item) => { %>
                            <div class="schedule-row <%= item.done ? "done" : "pending" %>">
                                <div class="schedule-time">
                                    <strong><%= item.time %></strong>
                                    <span><%= item.period %></span>
                                </div>
                                <div class="medicine-list">
                                    <% item.medicines.forEach((medicine) => { %>
                                        <span><%= medicine %></span>
                                    <% }) %>
                                </div>
                                <div class="schedule-status">
                                    <strong><%= item.status %></strong>
                                    <span><%= item.statusTime %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </article>

                <article class="panel sensor-panel">
                    <div class="panel-title">
                        <h2>센서 현황</h2>
                        <span class="pill success">정상</span>
                    </div>
                    <div class="sensor-grid">
                        <% data.sensors.forEach((sensor) => { %>
                            <div class="sensor-card" data-sensor-key="<%= sensor.key %>">
                                <span class="sensor-icon"><%= sensor.icon === "device" ? "▣" : sensor.icon === "temperature" ? "℃" : sensor.icon === "humidity" ? "%" : "↕" %></span>
                                <div>
                                    <span data-sensor-label><%= sensor.label %></span>
                                    <strong data-sensor-value><%= sensor.value %></strong>
                                    <small data-sensor-status><%= sensor.sub %></small>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                    <div class="latest-check">
                        <span>💊</span>
                        <div>
                            <small>마지막 복약 감지</small>
                            <strong><%= data.latestCheck.title %></strong>
                            <p><%= data.latestCheck.detail %></p>
                        </div>
                        <em>확인됨</em>
                    </div>
                </article>

                <article class="panel weekly-panel">
                    <div class="panel-title">
                        <h2>이번주 복약 현황</h2>
                        <span class="pill muted">6월 9일 - 15일</span>
                    </div>
                    <div class="week-table">
                        <% data.weekly.forEach((day) => { %>
                            <div class="week-col">
                                <strong><%= day.day %></strong>
                                <% day.states.forEach((state, index) => { %>
                                    <span class="dose <%= state %>"><%= index === 0 ? "아" : index === 1 ? "점" : "저" %></span>
                                <% }) %>
                                <em><%= day.rate %></em>
                            </div>
                        <% }) %>
                    </div>
                    <div class="legend">
                        <span><i class="success"></i>복약 완료</span>
                        <span><i class="pending"></i>복약 예정</span>
                        <span><i class="missed"></i>미복약</span>
                        <span><i class="empty"></i>미정</span>
                    </div>
                </article>

                <article class="panel chart-panel">
                    <div class="panel-title">
                        <h2>최근 30일 복약률 추이</h2>
                        <span class="pill success">개선 추세</span>
                    </div>
                    <div id="pillChart" class="bar-chart" aria-label="최근 30일 복약률 추이"></div>
                </article>

                <article class="panel alert-panel">
                    <div class="panel-title">
                        <h2>최근 알림 이력</h2>
                        <span class="pill danger">미확인 1건</span>
                    </div>
                    <div class="alert-list">
                        <% data.alerts.forEach((alert) => { %>
                            <div class="alert-row">
                                <span class="alert-dot <%= alert.tone %>"><%= alert.tone === "danger" ? "!" : alert.tone === "success" ? "✓" : "↻" %></span>
                                <strong><%= alert.title %></strong>
                                <time><%= alert.time %></time>
                            </div>
                        <% }) %>
                    </div>
                </article>
            </section>
        </main>
    </div>

    <script id="dashboardChartData" type="application/json"><%- JSON.stringify(data.chart) %></script>
    <script src="/js/chart.js"></script>
    <script src="/js/sensor-monitor.js"></script>
</body>
</html>
