<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/common.css">
  <link rel="stylesheet" href="/admin/style_send_message.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>


<main class="msg-container">
  <div class="msg-header">
    <h1 class="msg-header__title">회원 알림/메시지 발송</h1>
    <p class="msg-header__sub">복약안심서비스 이용자 및 보호자에게 실시간 앱 푸시 메시지를 전송합니다.</p>
  </div>

  <div class="msg-grid">
    
    <div class="msg-card msg-form-block">
      <h2>✉️ 메시지 작성</h2>
      <form id="messageForm" onsubmit="sendMessage(event)">
        
        <div class="form-group">
          <label>수신 대상 선택</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="targetUser" value="전체 회원" checked onclick="toggleTargetInput(false)"> 전체 회원
            </label>
            <label class="radio-label">
              <input type="radio" name="targetUser" value="특정 회원" onclick="toggleTargetInput(true)"> 특정 회원 지정
            </label>
          </div>
          <input type="text" id="specificUser" placeholder="회원 아이디 또는 이름을 입력하세요." style="display: none; margin-top: 10px;">
        </div>


        <div class="form-group">
          <label for="msgTitle">메시지 제목</label>
          <input type="text" id="msgTitle" placeholder="제목을 입력하세요." required oninput="syncPreview()">
        </div>

        <div class="form-group">
          <label for="msgContent">메시지 내용</label>
          <textarea id="msgContent" rows="5" placeholder="전송할 내용을 입력하세요." required oninput="syncPreview()"></textarea>
        </div>

        <button type="submit" class="btn-send">🚀 메시지 전송하기</button>
      </form>
    </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="msg-card history-block">
    <h2>📊 최근 발송 이력</h2>
    <div class="table-responsive">
      <table class="history-table">
        <thead>
          <tr>
            <th>발송 일시</th>
            <th>수신 대상</th>
            <th>유형</th>
            <th>메시지 제목</th>
            <th>상태</th>
          </tr>
        </thead>
        <tbody id="historyTableBody">
          <% history.forEach(function(item) { %>
          <tr>
            <td><%= item.date %></td>
            <td><span class="table-target"><%= item.target %></span></td>
            <td><%= item.type %></td>
            <td class="table-title"><%= item.title %></td>
            <td><span class="status-badge">발송 완료</span></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<div class="clearfix-padding"></div>


<script>
// 1. 특정 회원 지정 라디오 클릭 시 입력창 토글
function toggleTargetInput(show) {
    document.getElementById('specificUser').style.display = show ? 'block' : 'none';
}

// 2. 폰 내부 미리보기 실시간 텍스트 동기화
function syncPreview() {
    const title = document.getElementById('msgTitle').value;
    const content = document.getElementById('msgContent').value;
    
    document.getElementById('previewTitle').textContent = title.trim() || "제목을 입력하세요.";
    document.getElementById('previewContent').textContent = content.trim() || "전송할 내용을 입력하세요.";
}

// 3. 폰 내부 유형 뱃지 동기화
function updatePreviewBadge() {
    const type = document.getElementById('msgType').value;
    document.getElementById('previewBadge').textContent = type;
}

// 4. 메시지 전송 처리 (fetch 요청 후 리스트 추가)
function sendMessage(event) {
    event.preventDefault();

    const targetRadio = document.querySelector('input[name="targetUser"]:checked').value;
    const specificUser = document.getElementById('specificUser').value;
    const target = targetRadio === '특정 회원' ? `특정 (${specificUser})` : targetRadio;

    const type = document.getElementById('msgType').value;
    const title = document.getElementById('msgTitle').value;
    const content = document.getElementById('msgContent').value;

    fetch('/admin/send_message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ target, type, title, content })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert('회원들에게 메시지가 성공적으로 발송되었습니다!');
            location.reload(); // 새로고침하여 하단 테이블 이력 갱신
        }
    })
    .catch(err => console.error(err));
}
</script>
</body>
</html>