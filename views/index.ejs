<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/style_index.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

    <%- include('partials/user_partials/nav_index') %>
    
    <div id="top">
    </div>


  <!-- ===== 히어로 ===== -->
  <section class="hero">
    <div class="hero__inner">
      <span class="badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        스마트 약상자 기반 실시간 복약 모니터링
      </span>

      <h1 class="hero__title">
        어르신의 복약을<br>
        <span class="hero__title--accent">안심하고 맡기세요</span>
      </h1>

      <p class="hero__desc">
        IoT 스마트 약상자가 복약 여부를 자동으로 감지하고,<br>
        보호자에게 실시간으로 알려드립니다.
      </p>

      <div class="hero__btns">
        <a href="/login" class="btn btn--primary">서비스 시작하기</a>
        <a href="#how" class="btn btn--outline">이용 방법 보기</a>
      </div>

      <!-- 대시보드 미리보기 -->
      <div class="mockup" aria-label="복약 현황 대시보드 미리보기">
        <div class="mockup__header">
          <span class="mockup__dot mockup__dot--light"></span>
          <span class="mockup__dot mockup__dot--mid"></span>
          <span class="mockup__dot mockup__dot--dark"></span>
          <span class="mockup__label">복약 현황 대시보드 예시— 오늘 <%= new Date().toLocaleDateString('ko-KR') %></span>
        </div>

        <div class="stat-row">
          <div class="stat-card">
            <span class="stat-card__num stat-card__num--blue"><%= stats.total %></span>
            <span class="stat-card__label">총 등록 환자</span>
          </div>
          <div class="stat-card">
            <span class="stat-card__num stat-card__num--green"><%= stats.completed %></span>
            <span class="stat-card__label">정상 복약 완료</span>
          </div>
          <div class="stat-card">
            <span class="stat-card__num stat-card__num--red"><%= stats.warning %></span>
            <span class="stat-card__label">미복약 경보</span>
          </div>
        </div>

        <div class="pill-row">
          <% patients.forEach(p => { %>
            <span class="pill pill--<%= p.status %>">
              <% if (p.status === 'ok') { %>✓<% } else if (p.status === 'warn') { %>⚠<% } else { %>✗<% } %>
              <%= p.name %> — <%= p.label %>
            </span>
          <% }) %>
        </div>

        <div class="progress-wrap">
          <div class="progress-labels">
            <span>오늘 전체 복약률</span>
            <span class="progress-labels__val">75%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar__fill" style="width: 75%;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 핵심 기능 ===== -->
  <section class="features" id="features">
    <div class="container">
      <p class="section-tag">핵심 기능</p>
      <h2 class="section-title">복약 관리의 모든 것을<br>하나의 플랫폼에서</h2>
      <p class="section-sub">스마트 약상자 센서와 웹 대시보드가 연동되어 복약 상황을 빠짐없이 기록합니다.</p>

      <div class="features__grid">
        <div class="feature-card">
          <div class="feature-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <h3>실시간 복약 감지</h3>
          <p>무게 센서와 개폐 감지로 약 복용 여부를 자동으로 기록합니다.</p>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" aria-hidden="true">
              <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 01-3.46 0"/>
            </svg>
          </div>
          <h3>즉시 알림 발송</h3>
          <p>미복약 감지 시 보호자에게 즉각 알림을 보냅니다.</p>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" aria-hidden="true">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3>복약 이력 분석</h3>
          <p>일별·주별·월별 복약 패턴을 차트로 시각화하여 한눈에 파악합니다.</p>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <h3>다중 환자 관리</h3>
          <p>여러 어르신의 복약 현황을 보호자가 동시에 모니터링합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 이용 방법 ===== -->
  <section class="how" id="how">
    <div class="container">
      <p class="section-tag">이용 방법</p>
      <h2 class="section-title">4단계로 시작하는<br>스마트 복약 관리</h2>

      <div class="steps">
        <div class="step">
          <div class="step__num">1</div>
          <h4>기기 연결</h4>
          <p>스마트 약상자를 Wi-Fi에 연결하고 앱과 페어링합니다.</p>
        </div>
        <div class="step">
          <div class="step__num">2</div>
          <h4>환자 등록</h4>
          <p>복약 대상자와 보호자 정보를 시스템에 등록합니다.</p>
        </div>
        <div class="step">
          <div class="step__num">3</div>
          <h4>복약 스케줄 설정</h4>
          <p>아침·점심·저녁 복약 시간과 약 종류를 입력합니다.</p>
        </div>
        <div class="step">
          <div class="step__num">4</div>
          <h4>실시간 모니터링</h4>
          <p>대시보드에서 복약 현황을 확인하고 알림을 받습니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
<section class="cta">
  <div class="container cta__inner">
    <h2>복약 안심, 지금 바로 시작하세요</h2>
    <p>스마트 약상자 하나로 가족의 건강을 지킵니다.</p>
    <a href="/login" class="btn btn--white">로그인하고 시작하기 →</a>
  </div>
<a href="#top" class="top-btn" id="topBtn">
    <img src="/icon/KakaoTalk_20260703_112839241.png" alt="맨 위로">
</a>

</section>
</section>
  <!-- ===== 푸터 ===== -->
  <footer class="footer">
    <div class="container">
      <p>© 2025 복약안심서비스 &nbsp;|&nbsp; Team Jetson5 &nbsp;|&nbsp; 스마트 약상자 기반 복약 관리 플랫폼</p>
    </div>
  </footer>
  
<script>
const topBtn = document.getElementById("topBtn");

window.addEventListener("scroll", function () {

    if (window.scrollY > 300) {
        topBtn.classList.add("show");
    } else {
        topBtn.classList.remove("show");
    }

});

topBtn.addEventListener("click", function (e) {

    e.preventDefault();

    window.scrollTo({
        top: 0,
        behavior: "smooth"
    });

});
</script>

</body>
</html>