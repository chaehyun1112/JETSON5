<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/common.css">  
  <link rel="stylesheet" href="/user/user_service/style_medicine_buy_complete.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

  <% if (user && user.role === 'S') { %>
    <%- include('../../partials/user_partials/nav_senior') %>
<% } else { %>
      <%- include('../../partials/user_partials/nav_about') %>
<% } %>

  <main class="nopill-main">
    <div class="nopill-card buy-complete-card">

      <!-- 완료 아이콘 -->
      <div class="buy-complete__icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <h1 class="nopill-card__title">구매 완료!</h1>
      <p class="nopill-card__desc">
        스마트 약상자 구매가 완료되었습니다.<br>
        아래 약통 코드를 확인하고 약통 등록 시 사용해 주세요.
      </p>

      <!-- 약통 코드 출력 -->
      <div class="buy-complete__code-wrap">
        <p class="buy-complete__code-label">약통 코드</p>
        <div class="buy-complete__code">
          <span id="pillboxCode"><%= pillboxCode %></span>
          <button class="buy-complete__copy-btn" onclick="copyCode()" title="복사">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
            </svg>
          </button>
        </div>
        <p class="buy-complete__code-hint">이 코드는 약통 등록 시 필요합니다. 메모해 두세요!</p>
      </div>

      <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-top:0.5rem;">
        <% if (user && user.role === 'S') { %>
        <a href="/user/senior_info/senior_register-pillbox" class="btn btn--primary">지금 바로 약통 등록하기</a>
        <% } else { %>
        <a href="/user/user_service/register-pillbox" class="btn btn--primary">지금 바로 약통 등록하기</a>
        <% } %>
<% if (user && user.role === 'S') { %>
    <a href="/user/senior_service/senior_about" class="btn btn--outline">서비스 소개로 돌아가기</a>
<% } else { %>
    <a href="/user/user_service/about" class="btn btn--outline">서비스 소개로 돌아가기</a>
<% } %>      
</div>

    </div>
  </main>

<footer class="footer">
  © 2025 <span>복약안심서비스</span> | Team Jetson5 | 스마트 약상자 기반 복약 관리 플랫폼
</footer>

  <script>
    function copyCode() {
      const code = document.getElementById('pillboxCode').textContent;
      navigator.clipboard.writeText(code).then(() => {
        const btn = document.querySelector('.buy-complete__copy-btn');
        btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`;
        setTimeout(() => {
          btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;
        }, 2000);
      });
    }
  </script>

</body>
</html>