<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/common.css">  
  <link rel="stylesheet" href="/user/user_service/style_medicine_buy.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

    <% if (user && user.role === 'S') { %>
    <%- include('../../partials/user_partials/nav_senior') %>
<% } else { %>
      <%- include('../../partials/user_partials/nav_about') %>
<% } %>


  <!-- ===== 페이지 헤더 ===== -->
  <div class="about-header">
    <div class="about-header__inner">
      <p class="section-tag">약통 구매</p>
      <h1 class="about-header__title">스마트 약상자 구매</h1>
      <p class="about-header__sub">복약안심서비스와 연동되는 공식 스마트 약상자입니다.</p>
    </div>
  </div>

  <main class="about-main">
    <div class="about-container">

      <!-- 구매 카드 -->
      <div class="buy-card">

        <!-- 약통 이름 -->
        <h2 class="buy-card__name">스마트 약상자 Pro</h2>

        <!-- 약통 사진 영역 -->
        <div class="buy-card__img-wrap">
          <!-- 사진이 있으면 아래 img 태그의 src를 교체하세요 -->
          <!-- 예: <img src="/images/pillbox.jpg" alt="스마트 약상자 사진"> -->
          <div class="buy-card__img-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#93c5fd" stroke-width="1.2" aria-hidden="true">
              <rect x="2" y="7" width="20" height="15" rx="2"/>
              <path d="M10 7V5a2 2 0 014 0v2"/>
              <path d="M12 12v4M10 14h4"/>
            </svg>
            <p>약통 사진을 여기에 넣어주세요</p>
            <span>
              /public/images/ 폴더에 이미지를 넣고<br>
              img 태그의 src 경로를 교체하세요
            </span>
          </div>
        </div>

        <!-- 상품 설명 -->
        <div class="buy-card__info">
          <div class="buy-card__feature">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            무게 센서 & 개폐 감지 내장
          </div>
          <div class="buy-card__feature">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Wi-Fi 실시간 데이터 연동
          </div>
          <div class="buy-card__feature">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            복약안심서비스 웹 연결
          </div>
        </div>

        <!-- 가격 + 구매 버튼 -->
        <div class="buy-card__purchase">
          <div class="buy-card__price-wrap">
            <span class="buy-card__price-label">판매가</span>
            <span class="buy-card__price">89,000<span>원</span></span>
          </div>
          <form action="/user/user_service/medicine_buy" method="POST">
            <button type="submit" class="btn btn--primary buy-card__btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57L23 6H6"/>
              </svg>
              구매하기
            </button>
          </form>
        </div>

      </div>
      <!-- /buy-card -->

    </div>
  </main>

<footer class="footer">
  © 2026 <span>약속:藥束</span> | Team Jetson5 | 스마트 약상자 기반 복약 관리 플랫폼
</footer>

</body>
</html>