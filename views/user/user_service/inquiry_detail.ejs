<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/common.css">
    <link rel="stylesheet" href="/user/user_service/style_inquiry_detail.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
</head>

<body>

<% if (user && user.role === "S") { %>
    <%- include("../../partials/user_partials/nav_senior") %>
<% } else { %>
    <%- include("../../partials/user_partials/nav_index") %>
<% } %>



<main class="inquiry-container">
  <div class="table-responsive">
    <table class="inquiry-table">
    <div class="detail-card">

        <div class="detail-row">
            <span class="label">문의 유형</span>
            <span><%= inquiry.INQUIRY_TYPE %></span>
        </div>

        <div class="detail-row">
            <span class="label">처리 상태</span>

            <% if(inquiry.INQUIRY_STATUS === "답변완료"){ %>
                <span class="status done">답변완료</span>
            <% }else{ %>
                <span class="status wait">답변대기</span>
            <% } %>
        </div>

        <div class="detail-row">
            <span class="label">작성일</span>
            <span>
                <%= new Date(inquiry.CREATED_AT).toLocaleDateString("ko-KR") %>
            </span>
        </div>

        <div class="detail-title">
            <h3>제목 : <%= inquiry.INQUIRY_TITLE %></h3>
        </div>

        <div class="detail-content"><%= inquiry.INQUIRY_CONTENT %></div>

        <hr>

        <h3>관리자 답변</h3>

        <% if(inquiry.ANSWER_CONTENT){ %>

            <div class="answer-box"><%= inquiry.ANSWER_CONTENT %></div>

            <p class="answer-date">
                답변일 :
                <%= new Date(inquiry.ANSWERED_AT).toLocaleDateString("ko-KR") %>
            </p>

        <% }else{ %>

            <div class="answer-empty">
                아직 등록된 답변이 없습니다.
            </div>

        <% } %>

        <div class="btn-area">
            <a href="/user/user_service/check_inquiry" class="btn-back">
                목록으로
            </a>
        </div>

    </div>
    </table>

</main>

<footer class="footer">
  © 2026 <span>약속:藥束</span> | Team Jetson5 | 스마트 약상자 기반 복약 관리 플랫폼
</footer>

</body>
</html>