<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="stylesheet" href="/common.css">
<link rel="stylesheet" href="/user/user_info/style_protected.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

</head>
<body>

<%- include('../../partials/user_partials/nav_about') %>

<div class="protected-header">
    <div class="protected-header__inner">
        <p class="section-tag">보호대상 정보</p>
        <h1 class="protected-header__title">보호대상 수정</h1>
        <p class="protected-header__sub">
            보호대상 정보를 수정하세요.
        </p>
    </div>
</div>

<main class="protected-main">
<div class="protected-container">

<form
action="/user/user_info/protected/update/<%= person.SENIOR_ID %>"
method="POST">

<div class="pcard">

<div class="pcard__top">

<div class="pcard__avatar">
<%= person.SENIOR_NAME.charAt(0) %>
</div>

<div class="pcard__identity">
<h2 class="pcard__name">
<%= person.SENIOR_NAME %>
</h2>
</div>

</div>

<div class="pcard__grid">

<div class="pcard__row">
<span class="pcard__label">보호대상 아이디</span>

<input
type="text"
class="edit-input"
name="SENIOR_ID"
value="<%= person.SENIOR_ID %>"
readonly>

</div>

<div class="pcard__row">
<span class="pcard__label">이름</span>

<input
type="text"
class="edit-input"
name="SENIOR_NAME"
value="<%= person.SENIOR_NAME %>"
required>

</div>

<div class="pcard__row">
<span class="pcard__label">이메일</span>

<input
type="email"
class="edit-input"
name="SENIOR_EMAIL"
value="<%= person.SENIOR_EMAIL %>">

</div>

<div class="pcard__row">
<span class="pcard__label">연락처</span>

<input
type="text"
class="edit-input"
name="SENIOR_CONTACT"
value="<%= person.SENIOR_CONTACT %>">

</div>

<div class="pcard__row">
<span class="pcard__label">주소</span>

<input
type="text"
class="edit-input"
name="SENIOR_ADDR"
value="<%= person.SENIOR_ADDR %>">

</div>

<div class="pcard__row">
<span class="pcard__label">약통번호</span>

<input
type="text"
class="edit-input"
name="PILLBOX_NUM"
value="<%= person.PILLBOX_NUM %>">

</div>

<div class="pcard__row">
<span class="pcard__label">가입일</span>

<input
type="text"
class="edit-input"
value="<%= new Date(person.JOINED_AT).toLocaleDateString('ko-KR') %>"
readonly>

</div>

</div>

    <hr style="margin:30px 0; border:none; border-top:1px solid #e5e7eb;">

    <h3 style="margin-bottom:20px;">복약 스케줄</h3>

    <% if(scheduleList && scheduleList.length > 0){ %>

        <% scheduleList.forEach(function(schedule,index){ %>

        <div class="pcard__grid" style="margin-bottom:25px;">

            <input type="hidden"
                   name="scheduleCode[]"
                   value="<%= schedule.SCHEDULE_CODE %>">

            <div class="pcard__row">
                <span class="pcard__label">복약 시간</span>

                <input
                type="time"
                class="edit-input"
                name="takingTime[]"
                value="<%= schedule.TAKING_TIME %>">
            </div>

            <div class="pcard__row">
                <span class="pcard__label">요일</span>

                <select
                class="edit-input"
                name="takingDay[]">

                    <option value="월" <%= schedule.TAKING_DAY=="월"?"selected":"" %>>월</option>
                    <option value="화" <%= schedule.TAKING_DAY=="화"?"selected":"" %>>화</option>
                    <option value="수" <%= schedule.TAKING_DAY=="수"?"selected":"" %>>수</option>
                    <option value="목" <%= schedule.TAKING_DAY=="목"?"selected":"" %>>목</option>
                    <option value="금" <%= schedule.TAKING_DAY=="금"?"selected":"" %>>금</option>
                    <option value="토" <%= schedule.TAKING_DAY=="토"?"selected":"" %>>토</option>
                    <option value="일" <%= schedule.TAKING_DAY=="일"?"selected":"" %>>일</option>

                </select>

            </div>

            <div class="pcard__row">
                <span class="pcard__label">시작일</span>

                <input
                type="date"
                class="edit-input"
                name="startDate[]"
                value="<%= schedule.START_DATE %>">

            </div>

            <div class="pcard__row">
                <span class="pcard__label">종료일</span>

                <input
                type="date"
                class="edit-input"
                name="endDate[]"
                value="<%= schedule.END_DATE %>">

            </div>

        </div>

        <% }) %>

    <% } %>

    <div class="protected-add-wrap" style="margin-top:30px;">

        <a
        href="/user/user_info/protected"
        class="btn-add"
        style="background:#9ca3af;">
            취소
        </a>

        <button
        type="submit"
        class="btn-add">
            저장
        </button>

    </div>

</div>

</form>

</div>
</main>

<footer class="footer">
  © 2025 <span>복약안심서비스</span> | Team Jetson5 | 스마트 약상자 기반 복약 관리 플랫폼
</footer>

</body>
</html>