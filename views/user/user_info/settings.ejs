<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>복약안심서비스 | <%= pageTitle %></title>
  <link rel="stylesheet" href="/common.css">  
  <link rel="stylesheet" href="/user/user_info/style_settings.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

    <%- include('../../partials/user_partials/nav_dashboard') %>

  

  <main class="page">
    <section class="page-head">
      <div>
        <p class="section-tag">MY ACCOUNT</p>
        <h1 class="page-title">계정 정보와 알림, 개인정보를 한 곳에서 관리하세요</h1>
        <p class="page-sub">복약 알림을 놓치지 않도록 연락처와 알림 방식을 점검하고, 보호자에게 공유되는 개인정보 범위를 직접 조정할 수 있습니다.</p>
      </div>
    </section>

    <div class="settings-shell">
      <aside class="side-panel">
        <div class="user-card">
          <div class="avatar-row">
            <div>
              <strong><%= account.MEM_NAME %>님</strong>
              <span><%= account.MEM_EMAIL %></span>
            </div>
          </div>
          <span class="status-pill"><span class="status-dot"></span> 본인 인증 완료</span>
        </div>
      </aside>

      <div class="content-panel">
        <section class="section" id="account">
          <div class="section-head">
            <div>
              <h2>계정 정보</h2>
              <p>서비스 이용과 보호자 알림에 사용되는 기본 정보입니다.</p>
<br>

          <div class="card">
            <div class="info-strip">
              <div class="info-item">
                <span>회원 상태</span>
                <strong>
                <% if(account.MEM_ST === "P"){ %>
                보호자
                <% } else if(account.MEM_ST === "S"){ %>
                시니어
                <% } else { %>
                관리자
                <% } %>
                </strong>
              </div>
              <div class="info-item">
                <span>가입일</span>
                <strong><%= new Date(account.JOINED_AT).toLocaleDateString("ko-KR") %></strong>
              </div>
            </div>

            <form
              class="form-grid"
              action="/user/user_info/settings/update"
              method="post">
              <div class="field">
                <label for="id">아이디</label>
                <input id="id" name="MEM_ID" type="text" value="<%= account.MEM_ID %>">
              </div>
              <div class="field">
                <label for="name">이름</label>
                <input id="name" name="MEM_NAME" type="text" value="<%= account.MEM_NAME %>">
              </div>
              <div class="field">
                <label for="phone">휴대폰 번호</label>
                <input id="phone" name="MEM_CONTACT" type="tel" value="<%= account.MEM_CONTACT %>">
              </div>
              <div class="field">
                <label for="email">이메일</label>
                <input id="email" name="MEM_EMAIL" type="email" value="<%= account.MEM_EMAIL %>">
              </div>
              <div class="field field--full">
                <label for="address">주소</label>
                <input id="address" name="MEM_ADDR" type="text" value="<%= account.MEM_ADDR || ''%>">
              </div>
            </div>
          </section>

        <section class="section" id="notifications">
          <div class="section-head">
            <div>
              <h2>알림 설정</h2>
              <p>복약 시간, 지연 알림, 보호자 공유 방식을 설정합니다.</p>
            </div>
          </div>

          <div class="card">
            <div class="setting-list">
              <div class="setting-row">
                <div>
                  <h3>알림</h3>
                  <p>알림이 오는지 안오는지 설정이 가능합니다.</p>
                </div>
                <label class="switch" aria-label="복약 시간 알림 켜기">
                  <input type="checkbox" checked>
                  <span class="slider"></span>
                </label>
                </div>
              </div>
            </div>
        </section>

          <section class="section" id="privacy">
            <div class="section-head">
              <article class="privacy-card danger-zone">
                <h3>계정 및 데이터 삭제</h3>
                <p>서비스 탈퇴 시 계정 정보와 일부 데이터가 삭제될 수 있으며, 삭제된 정보는 복구할 수 없습니다.</p>
                <button type="button" class="btn btn--danger" onclick="deleteAccount()"> 탈퇴하기 </button>
              </article>
            </div>

              <div class="action-row">
                <button type="button" class="btn btn--outline" onclick="location.href='/user/user_info/settings'"> 변경 취소 </button>
                <button type="submit" class="btn btn--primary"> 설정 저장 </button>
              </div>
            </div>
          </form>
        </section>
      </div>
    </div>
  </main>

    <script>
    const chips = document.querySelectorAll(".chip");

    chips.forEach(chip => {
        chip.addEventListener("click", function () {
            this.classList.toggle("active");
        });
    });

    // 회원탈퇴
    function deleteAccount() {

        const result = confirm(
            "정말 회원탈퇴 하시겠습니까?\n\n삭제된 정보는 복구할 수 없습니다."
        );

        if (!result) {
            return;
        }

        const form = document.createElement("form");

        form.method = "POST";
        form.action = "/user/user_info/delete";

        document.body.appendChild(form);

        form.submit();
    }
    </script>
</body>
</html>