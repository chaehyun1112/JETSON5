<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>복약안심서비스 | <%= pageTitle %></title>
   <link rel="stylesheet" href="/user/user_info/style_settings.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

    <%- include('../../partials/user_partials/nav_dashboard') %>

  

  <main class="page">
    <section class="page-head">
      <div>
        <p class="section-tag">MY ACCOUNT</p>
        <h1 class="page-title">계정 정보와 알림, 개인정보를 한 곳에서 관리하세요</h1>
        <p class="page-sub">복약 알림을 놓치지 않도록 연락처와 알림 방식을 점검하고, 보호자에게 공유되는 개인정보 범위를 직접 조정할 수 있습니다.</p>
      </div>
    </section>

    <div class="settings-shell">
      <aside class="side-panel">
        <div class="user-card">
          <div class="avatar-row">
            <div>
              <strong><%= account.MEM_NAME %>님</strong>
              <span><%= account.MEM_EMAIL %></span>
            </div>
          </div>
          <span class="status-pill"><span class="status-dot"></span> 본인 인증 완료</span>
        </div>
        <nav class="side-nav" aria-label="설정 메뉴">
          <a class="is-current" href="#account"><span class="nav-icon">ID</span>계정 정보</a>
          <a href="#notifications"><span class="nav-icon">ON</span>알림 설정</a>
          <a href="#privacy"><span class="nav-icon">PW</span>개인정보 관리</a>
        </nav>


<script>
  // 사이드바의 모든 링크를 가져옵니다.
  const navLinks = document.querySelectorAll('.side-nav a');

  navLinks.forEach(link => {
    link.addEventListener('click', function() {
      // 1. 기존에 'is-current'가 붙어있던 메뉴에서 클래스 제거
      document.querySelector('.side-nav a.is-current')?.classList.remove('is-current');
      
      // 2. 방금 내가 클릭한 메뉴에 'is-current' 클래스 추가
      this.classList.add('is-current');
    });
  });
</script>
      </aside>

      <div class="content-panel">
        <section class="section" id="account">
          <div class="section-head">
            <div>
              <h2>계정 정보</h2>
              <p>서비스 이용과 보호자 알림에 사용되는 기본 정보입니다.</p>
<br>

          <div class="card">
            <div class="info-strip">
              <div class="info-item">
                <span>회원 상태</span>
                <strong>
                <% if(account.MEM_ST === "P"){ %>
                보호자
                <% } else if(account.MEM_ST === "S"){ %>
                시니어
                <% } else { %>
                관리자
                <% } %>
                </strong>
              </div>
              <div class="info-item">
                <span>가입일</span>
                <strong><%= new Date(account.JOINED_AT).toLocaleDateString("ko-KR") %></strong>
              </div>
              <div class="info-item">
                <span>마지막 로그인</span>
                <strong><%= account.lastLogin %></strong>
              </div>
            </div>

            <form
              class="form-grid"
              action="/user/user_info/settings/update"
              method="post">
              <div class="field">
                <label for="id">아이디</label>
                <input id="id" name="id" type="text" value="<%= account.MEM_ID %>">
              </div>
              <div class="field">
                <label for="name">이름</label>
                <input id="name" name="MEM_NAME" type="text" value="<%= account.MEM_NAME %>">
              </div>
              <div class="field">
                <label for="phone">휴대폰 번호</label>
                <input id="phone" name="MEM_CONTACT" type="tel" value="<%= account.MEM_CONTACT %>">
              </div>
              <div class="field">
                <label for="email">이메일</label>
                <input id="email" name="MEM_EMAIL" type="email" value="<%= account.MEM_EMAIL %>">
              </div>
              <div class="field field--full">
                <label for="address">주소</label>
                <input id="address" name="MEM_ADDR" type="text" value="<%= account.MEM_ADDR || ''%>">
              </div>
            </div>
          </section>

          <section class="section" id="notifications">
            <div class="section-head">
              <div>
                <h2>알림 설정</h2>
                <p>복약 시간, 지연 알림, 보호자 공유 방식을 설정합니다.</p>
              </div>
            </div>

            <div class="card">
              <div class="setting-list">
                <div class="setting-row">
                  <div>
                    <h3>복약 시간 알림</h3>
                    <p>등록된 약 복용 시간 10분 전에 알림을 보냅니다.</p>
                  </div>
                  <label class="switch" aria-label="복약 시간 알림 켜기">
                    <input type="checkbox" checked>
                    <span class="slider"></span>
                  </label>
                </div>
                <div class="setting-row">
                  <div>
                    <h3>미복용 지연 알림</h3>
                    <p>복용 확인이 없으면 본인에게 한 번 더 알려줍니다.</p>
                  </div>
                  <label class="switch" aria-label="미복용 지연 알림 켜기">
                    <input type="checkbox" checked>
                    <span class="slider"></span>
                  </label>
                </div>
                <div class="setting-row">
                  <div>
                    <h3>보호자 알림</h3>
                    <p>장시간 미복용 시 보호자에게 상태 알림을 전송합니다.</p>
                  </div>
                  <label class="switch" aria-label="보호자 알림 켜기">
                    <input type="checkbox" checked>
                    <span class="slider"></span>
                  </label>
                </div>
                <div class="setting-row">
                  <div>
                    <h3>건강 리포트 알림</h3>
                    <p>주간 복약 성공률과 주의 항목을 요약해 보냅니다.</p>
                  </div>
                  <label class="switch" aria-label="건강 리포트 알림 켜기">
                    <input type="checkbox">
                    <span class="slider"></span>
                  </label>
                </div>
              </div>

              <div class="time-grid">
                <div class="field">
                  <label for="method">알림 방식</label>
                  <select id="method" name="method">
                    <option>문자</option>
                    <option>전화 알림</option>
                  </select>
                </div>
                <div class="field">
                  <label for="quiet-start">방해금지 시작</label>
                  <input id="quiet-start" name="quietStart" type="time" value="22:00">
                </div>
                <div class="field">
                  <label for="quiet-end">방해금지 종료</label>
                  <input id="quiet-end" name="quietEnd" type="time" value="07:00">
                </div>
              </div>
            </div>
          </section>

          <section class="section" id="privacy">
            <div class="section-head">
              <div>
                <h2>개인정보 관리</h2>
                <p>민감 정보 공유 범위와 데이터 보관 방식을 관리합니다.</p>
              </div>
            </div>

            <div class="card">
              <div class="privacy-grid">
                <article class="privacy-card">
                  <h3>보호자 공유 범위</h3>
                  <p>보호자에게 공개되는 항목을 선택합니다.</p>
                  <div class="chip-row">
                    <button type="button" class="chip active">복약 여부</button>
                    <button type="button" class="chip">미복용 알림</button>
                    <button type="button" class="chip">주간 리포트</button>
                  </div>
                </article>
                <article class="privacy-card">
                  <h3>데이터 보관 기간</h3>
                  <p>복약 기록과 알림 이력의 보관 기간을 설정합니다.</p>
                  <select aria-label="데이터 보관 기간">
                    <option>6개월 보관</option>
                    <option>1년 보관</option>
                    <option>3년 보관</option>
                  </select>
                </article>
                <article class="privacy-card">
                  <h3>로그인 보안</h3>
                  <p>새 기기 로그인 시 본인 확인을 추가합니다.</p>
                  <label class="switch" aria-label="새 기기 본인 확인 켜기">
                    <input type="checkbox" checked>
                    <span class="slider"></span>
                  </label>
                </article>
                <article class="privacy-card danger-zone">
                  <h3>계정 및 데이터 삭제</h3>
                  <p>서비스 탈퇴 시 계정 정보와 일부 데이터가 삭제될 수 있으며, 삭제된 정보는 복구할 수 없습니다.</p>
                  <button type="button" class="btn btn--danger" onclick="deleteAccount()"> 탈퇴하기 </button>
                </article>
              </div>

              <div class="field field--full privacy-note">
                <label for="privacy-note">개인정보 처리 메모</label>
                <textarea id="privacy-note" name="privacyNote"><%= account.privacyNote %></textarea>
                <p class="help">메모는 본인 계정에서만 확인되며 보호자에게 자동 공유되지 않습니다.</p>
              </div>

              <div class="action-row">
                <button type="button" class="btn btn--outline" onclick="location.href='/user/user_info/settings'"> 변경 취소 </button>
                <button type="submit" class="btn btn--primary"> 설정 저장 </button>
              </div>
            </form>
          </div>
        </section>
      </div>
    </div>
  </main>

    <script>
    const chips = document.querySelectorAll(".chip");

    chips.forEach(chip => {
        chip.addEventListener("click", function () {
            this.classList.toggle("active");
        });
    });

    // 회원탈퇴
    function deleteAccount() {

        const result = confirm(
            "정말 회원탈퇴 하시겠습니까?\n\n삭제된 정보는 복구할 수 없습니다."
        );

        if (!result) {
            return;
        }

        const form = document.createElement("form");

        form.method = "POST";
        form.action = "/user/user_info/delete";

        document.body.appendChild(form);

        form.submit();
    }
    </script>
</body>
</html>
