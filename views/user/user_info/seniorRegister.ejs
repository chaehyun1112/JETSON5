<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>대상자 등록</title>
    <link rel="stylesheet" href="/common.css">
    <link rel="stylesheet" href="/user/user_service/seniorRegister.css">
</head>
<body>

    <main class="register-page">

        <section class="register-box">

        <div class="logo-area">
            <h1>약 속 : 藥 束</h1>
            <p>나에게 알맞은 약상자 케어 시스템</p>
        </div>

      <img src="/icon/main6_logo.png" class="logo-icon">
                </div>
            </div>

            <h2>보호 대상 등록</h2>

            <form action="/user/user_info/seniorRegister" method="post" class="register-form">

                <label>보호 대상 아이디</label>
                <input type="text" id="seniorId" name="seniorId" placeholder="대상자 아이디" required>

                <label>보호 대상 이름</label>
                <input type="text" id="name" name="name" placeholder="이름을 입력해주세요" required>

                <label>이메일</label>
                <div class="email-box">
                    <input type="email" id="email" name="email" placeholder="이메일을 입력해주세요" required>
                    <button type="button" id="sendBtn" class="btn-action"> 인증번호 보내기 </button>
                </div>

                <label>인증번호</label>
                <div class="email-box">
                    <input type="text" id="verifyCode" placeholder="인증번호를 입력해주세요">
                    <button type="button" id="verifyBtn" class="btn-action"> 인증번호 확인 </button>
                </div>

                <input type="hidden" id="emailVerified" name="emailVerified" value="N">

                <button type="submit" id="registerBtn" class="register-btn" disabled> 등록하기 </button>
            </form>

                <div class="links">
                    <% if (from === "pillbox") { %>
                        <a href="/user/user_service/register-pillbox">
                            약통 등록으로 돌아가기
                        </a>
                    <% } else { %>
                        <a href="/user/user_info/protected">
                            보호대상 정보로 돌아가기
                        </a>
                    <% } %>
                </div>

        </section>
    </main>
<script>
        let emailVerified = false;

        // 인증번호 보내기
        document.getElementById("sendBtn").addEventListener("click", () => {

            const seniorId = document.getElementById("seniorId").value.trim();
            const name = document.getElementById("name").value.trim();
            const email = document.getElementById("email").value.trim();

            if (!seniorId || !name || !email) {
                alert("아이디, 이름, 이메일을 모두 입력해주세요.");
                return;
            }

            fetch("/sendEmailCode", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    id: seniorId,
                    name: name,
                    email: email,
                    role: "S"
                })
            })
            .then(res => res.json())
            .then(data => {
                const msg = document.getElementById("emailMessage");


                if(data.success){
                    msg.innerHTML = "✔ 인증번호를 발송했습니다.";
                    msg.style.color = "green";
                }else{
                    msg.innerHTML = "❌ 메일 발송 실패";
                    msg.style.color = "red";
                }

            });

        });

        // 인증번호 확인
        document.getElementById("verifyBtn").addEventListener("click", () => {

            const email = document.getElementById("email").value.trim();
            const code = document.getElementById("verifyCode").value.trim();

            if (code === "") {
                alert("인증번호를 입력해주세요.");
                return;
            }

            fetch("/verifyEmailCode", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    email,
                    code
                })
            })
            .then(res => res.json())
            .then(data => {
                const msg = document.getElementById("verifyMessage");

                if (data.success) {

                    emailVerified = true;

                    document.getElementById("emailVerified").value = "Y";
                    document.getElementById("registerBtn").disabled = false;

                    msg.innerHTML="✔ 이메일 인증이 완료되었습니다.";
                    msg.style.color="green";

                } else {

                    emailVerified = false;

                    document.getElementById("emailVerified").value="N";
                    document.getElementById("registerBtn").disabled=true;

                    msg.innerHTML="❌ 인증번호가 올바르지 않습니다.";
                    msg.style.color="red";
                }

            });

        });

        // 등록하기 버튼 클릭 시 인증 여부 확인
        document.querySelector(".register-form").addEventListener("submit", (e) => {

            if (!emailVerified) {
                e.preventDefault();
                alert("이메일 인증을 완료해주세요.");
                return;
            }

        });
    </script>

</body>
</html>