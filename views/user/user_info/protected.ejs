<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/user/user_info/style_protected.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>

  <%- include('../../partials/user_partials/nav_about') %>

  <!-- ===== 페이지 헤더 ===== -->
  <div class="protected-header">
    <div class="protected-header__inner">
      <p class="section-tag">보호대상 정보</p>
      <h1 class="protected-header__title">보호대상 정보 관리</h1>
      <p class="protected-header__sub">등록된 보호대상자의 정보를 확인하고 관리하세요.</p>
    </div>
  </div>

  <main class="protected-main">
    <div class="protected-container">

      <% if (protectedPersons.length === 0) { %>
      <!-- ── 등록된 보호대상이 없을 때 ── -->
      <div class="protected-empty">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.4" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
        </svg>
        <p class="protected-empty__text">아직 등록된 보호대상자가 없습니다.</p>
        <a href="/user/user_service/protected/add" class="btn-add">+ 보호대상 등록하기</a>
      </div>

      <% } else { %>

      <!-- ── 보호대상 카드 목록 ── -->
      <div class="protected-list">
        <% protectedPersons.forEach(function(person) { %>
        <div class="pcard">

          <!-- 카드 상단: 아바타 + 이름 + 관계 -->
          <div class="pcard__top">
            <div class="pcard__avatar"><%= person.name.charAt(0) %></div>
            <div class="pcard__identity">
              <h2 class="pcard__name"><%= person.name %></h2>
              <span class="pcard__relation"><%= person.relation %></span>
            </div>
            <a href="/user/user_info/protected/edit/<%= person.id %>" class="pcard__edit">수정</a>
          </div>

          <!-- 카드 정보 그리드 -->
          <div class="pcard__grid">
            <div class="pcard__row">
              <span class="pcard__label">생년월일</span>
              <span class="pcard__value"><%= person.birthdate %></span>
            </div>
            <div class="pcard__row">
              <span class="pcard__label">성별</span>
              <span class="pcard__value"><%= person.gender %></span>
            </div>
            <div class="pcard__row">
              <span class="pcard__label">연락처</span>
              <span class="pcard__value"><%= person.phone %></span>
            </div>
            <div class="pcard__row">
              <span class="pcard__label">주소</span>
              <span class="pcard__value"><%= person.address %></span>
            </div>
            <div class="pcard__row">
              <span class="pcard__label">담당 의료진</span>
              <span class="pcard__value"><%= person.doctor %></span>
            </div>
            <div class="pcard__row">
              <span class="pcard__label">기저질환</span>
              <span class="pcard__value"><%= person.disease %></span>
            </div>
          </div>

          <!-- 복약 현황 간단 요약 -->
          <div class="pcard__footer">
            <div class="pcard__stat">
              <span class="pcard__stat-label">이번 달 복약률</span>
              <div class="pcard__bar-wrap">
                <div class="pcard__bar" style="width: <%= person.complianceRate %>%"></div>
              </div>
              <span class="pcard__stat-value"><%= person.complianceRate %>%</span>
            </div>
            <a href="/user/user_dashboard/main_dashboard" class="pcard__link">대시보드 보기 →</a>
          </div>

        </div>
        <% }); %>
      </div>

      <!-- 추가 버튼 -->
      <div class="protected-add-wrap">
        <a href="/user/user_info/protected/add" class="btn-add">+ 보호대상 추가하기</a>
      </div>

      <% } %>

    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>© 2025 복약안심서비스 &nbsp;|&nbsp; Team Jetson5 &nbsp;|&nbsp; 스마트 약상자 기반 복약 관리 플랫폼</p>
    </div>
  </footer>

</body>
</html>
