<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/user/user_dashboard/dashboard_pages.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body class="db-page">
  <%- include('../../partials/user_partials/nav_dashboard') %>

  <section class="db-header">
    <div class="db-header__inner">
      <div>
        <p class="db-header__greeting">오늘 복약 상태를 함께 확인합니다.</p>
        <h1 class="db-header__title">실시간 상태</h1>
        <p class="db-header__date"><%= new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' }) %></p>
      </div>
      <span class="status-badge"><span class="status-badge__dot"></span>실시간 모니터링</span>
    </div>
  </section>

  <main class="db-main">
    <div class="db-container">
      <section class="db-stats">
        <div class="db-stat-card">
          <span class="db-stat-card__emoji">👥</span>
          <div>
            <p class="db-stat-card__label">보호대상</p>
            <p class="db-stat-card__num"><%= summary.total %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <span class="db-stat-card__emoji">💚</span>
          <div>
            <p class="db-stat-card__label">정상</p>
            <p class="db-stat-card__num db-stat-card__num--green"><%= summary.ok %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <span class="db-stat-card__emoji">⏳</span>
          <div>
            <p class="db-stat-card__label">대기</p>
            <p class="db-stat-card__num db-stat-card__num--purple"><%= summary.warn %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <span class="db-stat-card__emoji">⚠️</span>
          <div>
            <p class="db-stat-card__label">확인 필요</p>
            <p class="db-stat-card__num db-stat-card__num--red"><%= summary.late %><span>명</span></p>
          </div>
        </div>
      </section>

      <section class="db-card">
        <div class="db-card__header">
          <h2 class="db-card__title">보호대상별 상태</h2>
          <div class="db-senior-select" id="seniorDropdown">
            <span class="db-senior-select__label">보호대상</span>
            <% const currentStatus = statuses.find(s => s.seniorId === selectedSeniorId) || statuses[0]; %>
            <span class="db-senior-select__value"><%= currentStatus ? currentStatus.seniorName : '-' %></span>
            <span class="db-senior-select__caret">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
            <div class="db-senior-select__menu">
              <div class="db-senior-select__menu-inner">
                <% statuses.forEach(s => { %>
                <a href="?senior=<%= s.seniorId %>" class="<%= s.seniorId === (currentStatus ? currentStatus.seniorId : '') ? 'is-active' : '' %>"><%= s.seniorName %></a>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

        <% if (statuses.length === 0) { %>
          <p class="db-empty">등록된 보호대상이 없습니다.</p>
        <% } else { %>
          <div class="db-status-grid">
            <% (currentStatus ? [currentStatus] : []).forEach((item) => { %>
              <article class="db-status-card db-status-card--<%= item.state %>">
                <div class="db-status-card__top">
                  <div>
                    <p class="db-status-card__name"><%= item.seniorName %></p>
                    <p class="db-status-card__meta">약통 번호 <%= item.pillboxNum || '-' %></p>
                  </div>
                  <span class="db-status db-status--<%= item.state === 'ok' ? 'ok' : item.state === 'late' ? 'late' : 'warn' %>">
                    <%= item.stateLabel %>
                  </span>
                </div>
                <div class="db-status-card__numbers">
                  <span>오늘 일정 <strong><%= item.todayTotal %></strong></span>
                  <span>완료 <strong><%= item.todayDone %></strong></span>
                  <span>미복용 <strong><%= item.todayMissed %></strong></span>
                </div>
                <div class="db-log-box">
                  <p>최근 로그</p>
                  <% const logTypeLabels = {
                       SLOT_OPEN: '약통 열림',
                       NO_ACTION: '움직임 없음',
                       BOX_CLOSED: '약통 닫힘',
                     }; %>
                  <strong><%= logTypeLabels[item.latestLogType] || item.latestLogType %></strong>
                  <span>칸: <%= item.latestSlotNum %> · <%= item.latestLoggedAt ? new Date(item.latestLoggedAt).toLocaleString('ko-KR') : '기록 없음' %></span>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>

  <script>
    const seniorDropdown = document.getElementById('seniorDropdown');
    if (seniorDropdown) {
      seniorDropdown.addEventListener('click', (e) => {
        seniorDropdown.classList.toggle('is-open');
      });
      document.addEventListener('click', (e) => {
        if (!seniorDropdown.contains(e.target)) {
          seniorDropdown.classList.remove('is-open');
        }
      });
    }
  </script>
</body>
</html>
