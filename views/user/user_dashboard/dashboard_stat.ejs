<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/user_dashboard/dashboard_pages.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body class="db-page">
  <%- include('../../partials/user_partials/nav_dashboard') %>

  <section class="db-header">
    <div class="db-header__inner">
      <div>
        <p class="db-header__greeting">약통 하드웨어 로그와 오늘 복약 상태를 함께 확인합니다.</p>
        <h1 class="db-header__title">실시간 상태</h1>
        <p class="db-header__date"><%= new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' }) %></p>
      </div>
      <span class="status-badge"><span class="status-badge__dot"></span>실시간 모니터링</span>
    </div>
  </section>

  <main class="db-main">
    <div class="db-container">
      <section class="db-stats">
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--blue">대</div>
          <div>
            <p class="db-stat-card__label">보호대상</p>
            <p class="db-stat-card__num"><%= summary.total %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--green">정</div>
          <div>
            <p class="db-stat-card__label">정상</p>
            <p class="db-stat-card__num db-stat-card__num--green"><%= summary.ok %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--purple">대</div>
          <div>
            <p class="db-stat-card__label">대기</p>
            <p class="db-stat-card__num db-stat-card__num--purple"><%= summary.warn %><span>명</span></p>
          </div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-card__icon db-stat-card__icon--red">확</div>
          <div>
            <p class="db-stat-card__label">확인 필요</p>
            <p class="db-stat-card__num db-stat-card__num--red"><%= summary.late %><span>명</span></p>
          </div>
        </div>
      </section>

      <section class="db-card">
        <div class="db-card__header">
          <h2 class="db-card__title">보호대상별 상태</h2>
          <a href="/user/user_dashboard/alerts" class="db-card__more">알림 관리</a>
        </div>

        <% if (statuses.length === 0) { %>
          <p class="db-empty">등록된 보호대상이 없습니다.</p>
        <% } else { %>
          <div class="db-status-grid">
            <% statuses.forEach((item) => { %>
              <article class="db-status-card db-status-card--<%= item.state %>">
                <div class="db-status-card__top">
                  <div>
                    <p class="db-status-card__name"><%= item.seniorName %></p>
                    <p class="db-status-card__meta">약통 번호 <%= item.pillboxNum || '-' %></p>
                  </div>
                  <span class="db-status db-status--<%= item.state === 'ok' ? 'ok' : item.state === 'late' ? 'late' : 'warn' %>">
                    <%= item.stateLabel %>
                  </span>
                </div>
                <div class="db-status-card__numbers">
                  <span>오늘 일정 <strong><%= item.todayTotal %></strong></span>
                  <span>완료 <strong><%= item.todayDone %></strong></span>
                  <span>미복용 <strong><%= item.todayMissed %></strong></span>
                </div>
                <div class="db-log-box">
                  <p>최근 로그</p>
                  <strong><%= item.latestLogType %></strong>
                  <span>칸: <%= item.latestSlotNum %> · <%= item.latestLoggedAt ? new Date(item.latestLoggedAt).toLocaleString('ko-KR') : '기록 없음' %></span>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>
</body>
</html>