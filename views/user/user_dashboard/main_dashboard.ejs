<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>

  <link rel="stylesheet" href="/common.css">
  <link rel="stylesheet" href="/user/user_dashboard/style_main_dashboard.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body class="db-page">

  <%- include('../../partials/user_partials/nav_dashboard') %>

  <div class="db-header">
    <div class="db-header__inner">
      <div>
        <p class="db-header__greeting">안녕하세요, <strong><%= user.name %></strong> 님 👋</p>
        <h1 class="db-header__title">오늘의 복약 인지 현황</h1>
        <p class="db-header__date"><%= new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' }) %></p>
      </div>

      <span class="status-badge status-badge--live">
        <span class="status-badge__dot"></span>
        실시간 모니터링 중
      </span>
    </div>
  </div>

  <main class="db-main">
    <div class="db-container">

      <section class="db-section">
        <div class="db-section__header">

    <h2 class="db-section__title">
        오늘 복용 현황
    </h2>
          <div class="db-senior-select" id="seniorDropdown">
            <span class="db-senior-select__label">보호대상</span>
            <% const currentSenior = seniorList.find(s=>s.SENIOR_ID===selectedSenior) || seniorList[0]; %>            
            <span class="db-senior-select__value"><%= currentSenior ? currentSenior.SENIOR_NAME : '-' %></span>
            <span class="db-senior-select__caret">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
            <div class="db-senior-select__menu">
              <div class="db-senior-select__menu-inner">
                <% seniorList.forEach(s => { %>
                  <a
                      href="?senior=<%= s.SENIOR_ID %>"
                      class="<%= s.SENIOR_ID===selectedSenior ? 'is-active':'' %>">

                      <%= s.SENIOR_NAME %>

                  </a>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
        <div class="db-today-list">
          <% const mealLabels = ['아침', '점심', '저녁', '취침 전'];
             const mealIcons  = ['🌅', '☀️', '🌙', '😴'];
             [today.morning, today.lunch, today.dinner, today.bedtime].forEach((rate, i) => {
               const statusClass = rate.includes('✅') ? 'db-meal-card--ok' : (rate.includes('❌') ? 'db-meal-card--miss' : '');
          %>
          <div class="db-meal-card <%= statusClass %>">
            <div class="db-meal-card__left">
              <span class="db-meal-card__icon"><%= mealIcons[i] %></span>
              <span class="db-meal-card__label"><%= mealLabels[i] %></span>
            </div>
            <span class="db-meal-card__rate"><%= rate %></span>
          </div>
          <% }) %>
        </div>
      </section>

      <section class="db-section">
        <h2 class="db-section__title">이번 주 요약</h2>
        <div class="db-stats">
            <div class="db-stat-card">
              <div class="db-stat-card__icon db-stat-card__icon--green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div>
                <p class="db-stat-card__label">평균 복약률</p>
                <p class="db-stat-card__num db-stat-card__num--green"><%= weekly.avgRate %><span>%</span></p>
              </div>
            </div>
            <div class="db-stat-card">
              <div class="db-stat-card__icon db-stat-card__icon--blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <div>
                <p class="db-stat-card__label">복약 일수</p>
                <p class="db-stat-card__num"><%= weekly.takenDays %><span>일</span></p>
              </div>
            </div>
            <div class="db-stat-card">
              <div class="db-stat-card__icon db-stat-card__icon--red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <p class="db-stat-card__label">복약 누락 횟수</p>
                <p class="db-stat-card__num db-stat-card__num--red"><%= weekly.missedCount %><span>회</span></p>
              </div>
            </div>
            <div class="db-stat-card">
              <div class="db-stat-card__icon db-stat-card__icon--purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
              <div>
                <p class="db-stat-card__label">총 등록 보호대상</p>
                <p class="db-stat-card__num db-stat-card__num--purple"><%= seniorList.length %><span>명</span></p>
              </div>
            </div>
          </div>
      </section>

      <div class="db-grid-2">

<div class="db-card">
  <div class="db-card__header">
    <h2 class="db-card__title">복약 일정</h2>
    <span class="db-card__sub">오늘 기준</span>
  </div>

  <ul class="db-schedule-list">
    <% schedule.forEach(s => { %>
    <li class="db-schedule-item">
      <div class="db-schedule-item__time-col">
        <span class="db-schedule-item__time"><%= s.time %></span>
        <span class="db-schedule-item__meal"><%= s.meal %></span>
      </div>
      <span class="db-status db-status--<%= s.status %>">
        <% if (s.status === 'ok') { %>완료
        <% } else if (s.status === 'warn') { %>지연
        <% } else { %>예정<% } %>
      </span>
    </li>
    <% }) %>
  </ul>
</div>
        

        <div class="db-card">
          <div class="db-card__header">
              <h2 class="db-card__title">감지 현황</h2>

              <div class="db-sensor-updated">
                  <span>최근 업데이트</span>
                  <strong><%= sensor.updatedAt %></strong>
              </div>
          </div>
          <ul class="db-sensor-list">
            <li class="db-sensor-item">
              <div class="db-sensor-item__icon-wrap db-sensor-item__icon-wrap--<%= sensor.lidOpen ? 'warn' : 'ok' %>">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8"/></svg>              </div>
              
              <div class="db-sensor-item__body">
                <p class="db-sensor-item__name">개폐 센서</p>
                <p class="db-sensor-item__val">약상자 <%= sensor.lidOpen ? '열림' : '닫힘' %></p>
              </div>

              <span class="db-sensor-badge db-sensor-badge--<%= sensor.lidOpen ? 'warn' : 'ok' %>">
                <%= sensor.lidOpen ? '열림' : '정상' %>
              </span>
            </li>
            <li class="db-sensor-item">
              <div class="db-sensor-item__icon-wrap db-sensor-item__icon-wrap--<%= sensor.powerStatus === 'Y' ? 'ok' : 'error' %>">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <polyline points="1 4 1 10 7 10"/>
                  <polyline points="23 20 23 14 17 14"/>
                  <path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/>
                </svg>
              </div>

              <div class="db-sensor-item__body">
                <p class="db-sensor-item__name">전원 연결 상태</p>

                <p class="db-sensor-item__val">
                    <%= sensor.lastHeartbeat %>
                </p>
              </div>

              <span class="db-sensor-badge db-sensor-badge--<%= sensor.powerStatus === 'Y' ? 'ok' : 'error' %>">
                <%= sensor.powerStatus === 'Y' ? '연결됨' : '연결 안됨' %>
              </span>
            </li>
            <li class="db-sensor-item">
              <div class="db-sensor-item__icon-wrap db-sensor-item__icon-wrap--blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="db-sensor-item__body">
                <p class="db-sensor-item__name">마지막 복약 감지</p>
                <p class="db-sensor-item__val"><%= sensor.lastDetected %></p>
              </div>
              <span class="db-sensor-badge db-sensor-badge--blue">감지됨</span>
            </li>
          </ul>
        </div>

      </div>


      <section class="db-section">
        <div class="db-card">
          <div class="db-card__header">
            <h2 class="db-card__title">이번주 복약 현황</h2>
            <span class="db-week-range"><%= weekly.table.range %></span>
          </div>

          <div class="db-week-grid">
            <% weekly.table.days.forEach(day => { %>
            <div class="db-week-col">
              <p class="db-week-day"><%= day.label %></p>

              <% ['morning','lunch','dinner','bedtime'].forEach((slot, i) => {
                   const status = day[slot] || 'unset';
                   const slotLabel = ['아침','점심','저녁','취침 전'][i];
              %>
              <div class="db-week-cell db-week-cell--<%= status %>"><%= slotLabel %></div>
              <% }) %>

              <p class="db-week-rate db-week-rate--<%= day.rate === null ? 'empty' : (day.rate >= 100 ? 'full' : (day.rate >= 70 ? 'mid' : 'low')) %>">
                <%= day.rate === null ? '-' : day.rate + '%' %>
              </p>
            </div>
            <% }) %>
          </div>

          <div class="db-week-legend">
            <span><span class="db-week-legend__dot db-week-legend__dot--done"></span>복약 완료</span>
            <span><span class="db-week-legend__dot db-week-legend__dot--pending"></span>복약 예정</span>
            <span><span class="db-week-legend__dot db-week-legend__dot--missed"></span>미복약</span>
            <span><span class="db-week-legend__dot db-week-legend__dot--unset"></span>미정</span>
          </div>
        </div>
      </section>

      <section class="db-section">
        <div class="db-card">
          <div class="db-card__header">
            <h2 class="db-card__title">최근 알림 이력</h2>
            <% if (alerts.length > 3) { %>
            <a href="#" id="alertToggle" class="db-card__more">전체 보기 →</a>
            <% } %>
          </div>
          <ul class="db-alert-list">
            <% alerts.forEach((a, i) => { %>

            <li class="db-alert db-alert--<%= a.className %><%= i >= 3 ? ' db-alert--extra' : '' %>">

              <div class="db-alert__body">

                <div class="db-alert__head">

                  <strong><%= a.SENIOR_NAME %></strong>

                  <span>
                    <%= ({
                      TAKEN:'복용 완료',
                      MISSED_MEDICINE:'복약 누락',
                      WARN:'경고',
                      SYSTEM:'시스템'
                    })[a.ALERT_TYPE] || a.ALERT_TYPE %>
                  </span>

                </div>

                <p class="db-alert__msg">
                  <%= a.ALERT_MSG %>
                </p>

                <p class="db-alert__time">

                  <%= a.ALERT_TIME
                      ? new Date(a.ALERT_TIME).toLocaleString('ko-KR')
                      : '-' %>

                  · 수신 여부 <%= a.IS_RECEIVED %>

                </p>

              </div>

            </li>

            <% }) %>
          </ul>
        </div>
      </section>

    </div>
  </main>


<footer class="footer">
  © 2026 <span>약속:藥束</span> | Team Jetson5 | 스마트 약상자 기반 복약 관리 플랫폼
</footer>

  <script>
    const alertToggle = document.getElementById('alertToggle');
    if (alertToggle) {
      let expanded = false;
      alertToggle.addEventListener('click', (e) => {
        e.preventDefault();
        expanded = !expanded;
        document.querySelectorAll('.db-alert--extra').forEach((item) => {
          item.classList.toggle('db-alert--extra-visible', expanded);
        });
        alertToggle.textContent = expanded ? '접기 ←' : '전체 보기 →';
      });
    }
  </script>

    <script>
    const seniorDropdown = document.getElementById('seniorDropdown');
    if (seniorDropdown) {
      seniorDropdown.addEventListener('click', (e) => {
        seniorDropdown.classList.toggle('is-open');
      });
      document.addEventListener('click', (e) => {
        if (!seniorDropdown.contains(e.target)) {
          seniorDropdown.classList.remove('is-open');
        }
      });
    }
  </script>


</body>
</html>