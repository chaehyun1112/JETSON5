<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>복약 기록</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-shell">
        <%- include("partials/sidebar", { resident: data.resident, activePage: "records" }) %>

        <main class="dashboard records-page">
            <%- include("partials/topbar", {
                title: "복약 기록",
                lastUpdated: data.lastUpdated,
                avatarLabel: "김"
            }) %>

            <%- include("partials/records-table-panel", {
                range: data.range,
                records: data.records,
                pagination: data.pagination
            }) %>
        </main>
    </div>
</body>
</html>
